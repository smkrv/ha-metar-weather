{
  "config": {
    "step": {
      "user": {
        "title": "METAR Weather Setup",
        "description": "Set up METAR weather monitoring.\n\nData sources (NOAA):\n• Primary: Aviation Weather Center API (aviationweather.gov)\n• Fallback: NOAA FTP (tgftp.nws.noaa.gov)\n\nPlease make sure you comply with the NOAA data usage terms.",
        "data": {
          "icao": "ICAO Airport Code",
          "terms_accepted": "I accept the terms and conditions of the data source"
        }
      },
      "units": {
        "title": "Unit Configuration",
        "description": "Select display units for weather data.\nChoose 'Auto' to use Home Assistant system settings.\nChoose 'Native (METAR)' to follow the units used in this station's own reports (e.g. knots, meters and hPa for ICAO stations; knots, statute miles and inHg for US stations; cloud heights in feet).",
        "data": {
          "temperature_unit": "Temperature",
          "wind_speed_unit": "Wind Speed",
          "visibility_unit": "Visibility",
          "pressure_unit": "Pressure",
          "altitude_unit": "Cloud Height / Altitude"
        }
      }
    },
    "error": {
      "invalid_icao": "Invalid ICAO code format",
      "terms_not_accepted": "You must accept the terms and conditions",
      "station_exists": "This station is already configured",
      "station_exists_other_entry": "This station is already configured in another integration entry",
      "cannot_connect": "Failed to connect to station",
      "unknown": "Unexpected error"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "METAR Settings",
        "menu_options": {
          "units": "Configure Units",
          "stations": "Manage Stations",
          "station_remove": "Remove Station"
        }
      },
      "units": {
        "title": "Unit Configuration",
        "description": "Select display units for weather data.\nChoose 'Auto' to use Home Assistant system settings.\nChoose 'Native (METAR)' to follow the units used in this station's own reports (e.g. knots, meters and hPa for ICAO stations; knots, statute miles and inHg for US stations; cloud heights in feet).",
        "data": {
          "temperature_unit": "Temperature",
          "wind_speed_unit": "Wind Speed",
          "visibility_unit": "Visibility",
          "pressure_unit": "Pressure",
          "altitude_unit": "Cloud Height / Altitude"
        }
      },
      "stations": {
        "title": "Manage Stations",
        "description": "Currently configured stations:\n{stations}"
      },
      "station_add": {
        "title": "Add Station",
        "description": "Enter ICAO code for the new station",
        "data": {
          "icao": "ICAO Airport Code"
        }
      },
      "station_configure": {
        "title": "Station Configuration",
        "description": "Would you like to add another station?",
        "data": {
          "add_another": "Add another station"
        }
      },
      "station_remove": {
        "title": "Remove Station",
        "description": "Select a station to remove. Note: At least one station must remain.",
        "data": {
          "station": "Station to remove"
        }
      }
    },
    "error": {
      "cannot_remove_last": "Cannot remove the last station",
      "station_exists": "This station is already configured in this entry",
      "station_exists_other_entry": "This station is already configured in another integration entry"
    }
  },
  "exceptions": {
    "invalid_icao_format": {
      "message": "Invalid ICAO code format: {station}"
    },
    "station_not_found": {
      "message": "Station {station} not found in any config entry"
    },
    "station_not_configured": {
      "message": "Station {station} is not configured"
    },
    "storage_not_initialized": {
      "message": "Storage not initialized"
    },
    "clear_history_timeout": {
      "message": "Timeout clearing history for station {station}"
    },
    "clear_history_failed": {
      "message": "Failed to clear history for station {station}: {error}"
